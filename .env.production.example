# ============================================================================
# EventArc Production Environment Variables
# ============================================================================
# Copy to .env and fill in all values before deploying.
# For Dokploy: add these in the Dokploy UI under Environment Variables.
#
# Generate secrets:
#   openssl rand -hex 32    → HMAC_SECRET
#   openssl rand -hex 24    → PG_PASSWORD
# ============================================================================

# ── Domains ────────────────────────────────────────────────────────────────
# Your domain names (used by Traefik for routing + SSL)
FRONTEND_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com

# ── Security ───────────────────────────────────────────────────────────────
# HMAC secret shared between Go backend and Convex (minimum 32 bytes)
HMAC_SECRET=

# PostgreSQL password
PG_PASSWORD=

# ── Convex ─────────────────────────────────────────────────────────────────
# From Convex dashboard after `npx convex deploy`
VITE_CONVEX_URL=https://your-project.convex.cloud
VITE_CONVEX_SITE_URL=https://your-project.convex.site
CONVEX_URL=https://your-project.convex.cloud
CONVEX_DEPLOYMENT_TOKEN=

# ── Frontend ───────────────────────────────────────────────────────────────
# Go API URL as seen by the browser
VITE_API_URL=https://api.yourdomain.com

# ── Cloudflare R2 ─────────────────────────────────────────────────────────
# Required for QR code and invitation card generation
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=eventarc-qr
R2_PUBLIC_URL=https://cdn.yourdomain.com

# ── SMS Provider ──────────────────────────────────────────────────────────
# Optional — required only for SMS invitations
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_SENDER_ID=
SMS_PROVIDER_BASE_URL=https://api.sms.net.bd

# ── Resource Tuning (optional) ────────────────────────────────────────────
# Adjust based on your VPS size (see docs/SIZING-GUIDE.md)
#
# GOMAXPROCS=4                  # API server CPU cores
# WORKER_GOMAXPROCS=2           # Worker CPU cores
# WORKER_GOMEMLIMIT=450MiB     # Worker memory limit (Go runtime)
# WORKER_MEMORY_LIMIT=512M     # Worker container memory limit
# WORKER_CPU_LIMIT=2            # Worker container CPU limit
# REDIS_MAXMEMORY=256mb         # Redis max memory
# ASYNQ_CONCURRENCY=64          # Background job concurrency
