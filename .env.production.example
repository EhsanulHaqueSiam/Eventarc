# ============================================================================
# EventArc Production Environment Variables
# ============================================================================
# Copy to .env and fill in all values before deploying.
# For Dokploy: add these in the Dokploy UI under Environment Variables.
#
# Generate secrets:
#   openssl rand -hex 32    → HMAC_SECRET
#   openssl rand -hex 24    → PG_PASSWORD
#
# ── Switching Convex deployments ──
# All Convex URLs below are env-driven. To point at a different Convex
# project (e.g. staging vs prod, or a fresh deployment), update the three
# CONVEX_* vars and redeploy. The backend Go schema is owned by the Go
# migrations in backend/migrations/ and runs automatically on deploy; the
# Convex schema is owned by convex/schema.ts and is applied when you run
# `npx convex deploy --prod` from a machine that has the Convex CLI auth
# set for that project. Always run `npx convex deploy` *before* restarting
# the Docker services so HTTP actions referenced by the Go backend exist.
# ============================================================================

# ── Domains ────────────────────────────────────────────────────────────────
# Your domain names (used by Traefik for routing + SSL)
FRONTEND_DOMAIN=app.yourdomain.com
API_DOMAIN=api.yourdomain.com

# ── Security ───────────────────────────────────────────────────────────────
# HMAC secret shared between Go backend and Convex (minimum 32 bytes).
# MUST be identical to the HMAC_SECRET set via `npx convex env set` in the
# matching Convex deployment, or Go↔Convex sync will fail signature checks.
HMAC_SECRET=

# PostgreSQL password
PG_PASSWORD=

# ── Convex ─────────────────────────────────────────────────────────────────
# Convex exposes two hostnames per deployment. They are NOT interchangeable:
#
#   *.convex.cloud  → client SDK endpoint (queries, mutations, subscriptions)
#   *.convex.site   → HTTP actions (httpAction) — this is what Go calls for
#                      /internal/sync/guest-card, /guest-checkin, /food-consumption
#
# Copy them verbatim from the Convex dashboard after `npx convex deploy --prod`.
VITE_CONVEX_URL=https://your-project.convex.cloud
VITE_CONVEX_SITE_URL=https://your-project.convex.site

# Used by the Go backend to POST to Convex httpAction routes. MUST be the
# .convex.site host — using .convex.cloud here causes every Go→Convex write
# to 404 silently and Convex will drift out of sync.
CONVEX_URL=https://your-project.convex.site

# Also point Convex back at the Go API so Convex internalActions (e.g.
# pushEventToGo, syncFoodRules) can reach the backend. Set this via
# `npx convex env set GO_API_URL https://api.yourdomain.com` — it lives in
# Convex's environment, not this file, but is listed here as a reminder.
# GO_API_URL=https://api.yourdomain.com

# ── Frontend ───────────────────────────────────────────────────────────────
# Go API URL as seen by the browser (baked into the Vite bundle at build time)
VITE_API_URL=https://api.yourdomain.com

# ── Umami analytics (optional) ─────────────────────────────────────────────
# Leave blank to disable tracking entirely (analytics.ts no-ops).
# Deploy docker-compose.umami.yml as a separate Dokploy app, then:
#   1. Log in, add a website in Umami admin UI.
#   2. Copy Website ID + tracker script URL from the Umami "Edit" page.
#   3. Fill these two vars and redeploy the frontend.
# Example: https://analytics.altoras.com/script.js
VITE_UMAMI_WEBSITE_ID=
VITE_UMAMI_SCRIPT_URL=

# ── Cloudflare R2 ─────────────────────────────────────────────────────────
# Required for QR code and invitation card generation
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=eventarc-qr
R2_PUBLIC_URL=https://cdn.yourdomain.com

# ── SMS Provider ──────────────────────────────────────────────────────────
# Optional — required only for SMS invitations
SMS_PROVIDER_API_KEY=
SMS_PROVIDER_SENDER_ID=
SMS_PROVIDER_BASE_URL=https://api.sms.net.bd

# ── Resource Tuning (optional) ────────────────────────────────────────────
# Adjust based on your VPS size (see docs/SIZING-GUIDE.md)
#
# GOMAXPROCS=4                  # API server CPU cores
# WORKER_GOMAXPROCS=2           # Worker CPU cores
# WORKER_GOMEMLIMIT=450MiB     # Worker memory limit (Go runtime)
# WORKER_MEMORY_LIMIT=512M     # Worker container memory limit
# WORKER_CPU_LIMIT=2            # Worker container CPU limit
# REDIS_MAXMEMORY=256mb         # Redis max memory
# ASYNQ_CONCURRENCY=64          # Background job concurrency
