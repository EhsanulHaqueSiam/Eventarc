# ============================================================================
# Umami (Analytics) Environment Variables
# ============================================================================
# Use these in the Dokploy app that runs docker-compose.umami.yml.
# This is a SEPARATE app from EventArc — do not mix these with the main
# .env.production values.
#
# Generate secrets:
#   openssl rand -hex 24    → UMAMI_DB_PASSWORD
#   openssl rand -hex 32    → UMAMI_APP_SECRET
# ============================================================================

# Subdomain that will serve the Umami dashboard + tracker script
UMAMI_DOMAIN=analytics.altoras.com

# Session / JWT secret for Umami
UMAMI_APP_SECRET=

# Postgres password for Umami's own DB (isolated from EventArc)
UMAMI_DB_PASSWORD=

# Optional: rename the tracker script path to bypass ad blockers. For example,
# set this to "data.js" so the embed becomes /data.js. The website id and
# `data-website-id` attribute are unchanged.
# UMAMI_TRACKER_SCRIPT_NAME=script
